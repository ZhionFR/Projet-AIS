flowchart TB

    subgraph Z0["Zone 0 - Reseau public (Internet, non fiable)"]
        direction LR
        U["Utilisateur<br/>(navigateur web)"]
        ADM["Administrateur systeme<br/>(reseau d'administration distant)"]
    end

    subgraph Z1["Zone 1 - Perimetre reseau (routage inter-segments)"]
        direction TB
        FW["Pare-feu PfSense<br/>politique par defaut : tout refuser<br/>regles explicites par flux autorise<br/>tout flux inter-segment transite ici (defense en profondeur)"]
    end

    subgraph Z2["Zone 2 - DMZ (serveur applicatif)"]
        direction TB
        IPT1["iptables local SRV-1<br/>n'accepte 80/tcp (redirige vers 5000) que depuis le pare-feu<br/>n'accepte 2222/tcp que depuis le bastion"]
        SRV1["SRV-1 : application web (redirection 80 vers 5000)"]
    end

    subgraph Z3["Zone 3 - Management (bastion)"]
        direction TB
        BAST["Bastion : point de passage unique<br/>pour toute administration<br/>authentification par cle + journalisation des sessions"]
    end

    subgraph Z4["Zone 4 - Interne / donnees"]
        direction TB
        IPT2["iptables local SRV-2<br/>n'accepte 5432/tcp que depuis le pare-feu (source SRV-1 uniquement)<br/>n'accepte 2222/tcp que depuis le bastion"]
        SRV2["SRV-2 : base de donnees PostgreSQL"]
    end

    subgraph Z5["Zone 5 - Supervision (SIEM)"]
        direction TB
        SIEM["SIEM : collecte les journaux de<br/>SRV-1, SRV-2, Bastion et PfSense<br/>flux de journalisation unidirectionnel"]
    end

    U -->|HTTP port 80| FW
    ADM -->|SSH port 2222, reseau admin uniquement| FW
    FW -->|flux web autorise| IPT1
    IPT1 --> SRV1
    FW -->|flux admin autorise, bastion uniquement| BAST
    BAST -->|rebond ssh, relaye par le pare-feu| FW
    FW -->|rebond ssh vers SRV-1| IPT1
    FW -->|rebond ssh vers SRV-2| IPT2
    IPT2 --> SRV2
    SRV1 -->|requete SQL, relai oblige| FW
    FW -->|ACL 5432/tcp uniquement| IPT2

    FW -.->|journalisation| SIEM
    SRV1 -.->|journalisation| SIEM
    SRV2 -.->|journalisation| SIEM
    BAST -.->|journalisation| SIEM

    style Z0 fill:#3a1a1a,stroke:#c0392b,color:#fff
    style Z1 fill:#3a2a10,stroke:#e67e22,color:#fff
    style Z2 fill:#123024,stroke:#27ae60,color:#fff
    style Z3 fill:#1a2a3a,stroke:#2980b9,color:#fff
    style Z4 fill:#2a1a30,stroke:#8e44ad,color:#fff
    style Z5 fill:#1a1a2a,stroke:#5b5ba6,color:#fff
